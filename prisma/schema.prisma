// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

// when writing in prisma you dont use SQL it will do it for you

model Profile {
  //name              type      @rules or behavior 
  id                  String   @id @default(uuid()) //uuid is a long random string (safer than a simple counting num for user ID)
  email               String   @unique //means you cannot have two accts w same email 
  points              Int      @default(0) //every new user starts w default of 0 pts
  background          String   @default("cozy") //every new user starts w the cozy theme 
  createdAt           DateTime @default(now()) //now() fills in current date and time 
  photos              Photo[]
  placedStickers      PlacedSticker[] //a user can place many stickers 
}

//@id = fields primary key, unique identifier for each row 
//@default(...) sets a value automatically when a new row is created and you didnt provide one 

//Add this relation line INSIDE your existing Profile model --
model Photo {
  id        String   @id @default(uuid()) //unique id for each photo, auto generated 
  path      String
  x         Int      @default(0) // horicontal psoition on the board
  y         Int      @default(0) //vertical position on board 
  frame     String   @default("classic") //which polaroid frame style this photo uses 
  createdAt DateTime @default(now()) //when it was uploaded
  profileId String
  profile   Profile  @relation(fields: [profileId], references: [id]) //connected profileId to Profile.id
}
//A sticker the user has unlocked AND placed on thier board
//One row = one sticker sitting at one spot on the persons board 
model PlacedSticker{
  id              String     @id @default(uuid()) //unique id for each photo, auto generated 
  stickerKey      String                          // "sticker-1: tells us which PNG 
  x               Float      @default(0)          // horicontal psoition on the board
  y               Float      @default(0)          //vertical position on board 

//Link this sticker to the Profile (user) that owns it 
profile           Profile    @relation(fields: [profileId], references: [id])
profileId         String                          //The owner's Profile id 

createdAt         DateTime   @default(now())

}